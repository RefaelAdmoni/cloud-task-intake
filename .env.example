NODE_ENV=development
PORT=3000
DATABASE_URL=postgresql://taskuser:taskpass@localhost:5432/taskdb
CORS_ORIGIN=http://localhost:5173

# JWT — must be at least 32 characters; change before deploying
JWT_SECRET=changeme-replace-in-production-min-32-chars
JWT_EXPIRES_IN=24h

QUEUE_PROVIDER=redis
REDIS_URL=redis://localhost:6379

STORAGE_PROVIDER=local
LOCAL_STORAGE_PATH=./uploads
PUBLIC_STORAGE_BASE_URL=http://localhost:3000/uploads

TELEGRAM_BOT_TOKEN=
TELEGRAM_WEBHOOK_SECRET=
